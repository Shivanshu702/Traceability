# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev default):
DATABASE_URL=sqlite:///./mes.db
# PostgreSQL (production — recommended):
# DATABASE_URL=postgresql://user:password@localhost:5432/traceability

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
TOKEN_TTL_MINUTES=60

# Set to "false" to disable open registration (admin must create users)
OPEN_REGISTRATION=true

# ── Frontend URL (used in QR code generation) ─────────────────────────────────
FRONTEND_URL=https://your-frontend-domain.com

# ── Email / SMTP (can also be set via Admin UI) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your@gmail.com

# Comma-separated list of alert recipients
ALERT_EMAILS=manager@company.com,supervisor@company.com

# Enable alerts (can also be toggled per-tenant in Admin UI)
STUCK_ALERT_ENABLED=false
STUCK_HOURS=1
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_HOUR=8
FIFO_ALERT_ENABLED=true
