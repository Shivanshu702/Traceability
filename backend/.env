# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to disable /docs and /dev/* routes.
ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev default):
# DATABASE_URL=sqlite:///./mes.db
# PostgreSQL (production — recommended):
DATABASE_URL=postgresql://postgres:Rajesh123@localhost:5432/traceability


# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=dfa75ef87adf25488765b929f29420f4384bb70a23a5a95860130662289b9bfe8a9255eb13825fc8df58a339d4228abc45185bfec8ad721a40a8097b93ab9cd2
TOKEN_TTL_MINUTES=60

# Set to "false" to disable open registration (admin must create users)
OPEN_REGISTRATION=false

# ── Developer key (non-production only) ───────────────────────────────────────
# Used by /dev/* endpoints. These routes are disabled when ENV=production,
# so this key is only relevant in dev/staging environments.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DEV_KEY=719fc23a12f0250dac86a2f48b035d75b02264306d3f10c7f4f63423cb331bde

# ── Frontend / CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must match your deployed frontend URL.
# Example: ALLOWED_ORIGINS=https://traceability.yourcompany.com
ALLOWED_ORIGINS=https://traceability-frontend-delta.vercel.app

# ── Frontend URL (used in QR code generation) ─────────────────────────────────
FRONTEND_URL=https://traceability-frontend-delta.vercel.app

# ── Email / SMTP (can also be set via Admin UI) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=true
SMTP_USER=shivanshugarg702@gmail.com
SMTP_PASSWORD=ruqpzspixkbpajwo
FROM_EMAIL=shivanshugarg702@gmail.com

# Comma-separated list of alert recipients
ALERT_EMAILS=manager@company.com,supervisor@company.com

# Tenant allowlist — comma-separated uppercase IDs (leave empty = single-tenant mode).
ALLOWED_TENANTS=

# Enable alerts (can also be toggled per-tenant in Admin UI)
STUCK_ALERT_ENABLED=false
STUCK_HOURS=1
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_HOUR=8
FIFO_ALERT_ENABLED=true

# ── Database connection pool ───────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Redis shared cache (optional) ─────────────────────────────────────────────
# Leave commented out to use the in-process fallback cache (fine for 1 worker).
# Uncomment and fill in if you add a Redis instance on Render.
# REDIS_URL=redis://red-xxxxxxxxxxxx:6379